rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // O caminho utilizado na aplicação é users/{uid}/cubagem_items
    match /users/{userId}/{document=**} {
      // Apenas permite leitura e escrita se o utilizador estiver autenticado
      // e o seu ID de utilizador corresponder à pasta acedida
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}